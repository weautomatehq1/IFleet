# ---------------------------------------------------------------------------
# VPS — fleet control scripts (fleet:pause / fleet:resume / fleet:status)
# ---------------------------------------------------------------------------

# IP or hostname of your VPS. Scripts fall back to the hardcoded default if unset.
VPS_HOST=your.vps.ip.or.hostname

# ---------------------------------------------------------------------------
# Discord — daemon Discord client + control-plane HMAC bridge
# ---------------------------------------------------------------------------

# Bot token from the Discord developer portal. Required by the ifleet daemon
# (src/discord/index.ts) and the standup/canary cron jobs.
DISCORD_BOT_TOKEN=

# Shared secret for the HMAC-signed /control endpoint. Must match the secret
# the Discord bot uses to sign requests. Required by src/server.ts.
IFLEET_HMAC_SECRET=

# Default Discord channel for DiscordOut posts when no route matches.
# #ifleet-ops is the typical fallback.
DISCORD_FALLBACK_CHANNEL_ID=

# Channel for ops-level alerts (canary, doctor-scan). Falls back to
# DISCORD_FALLBACK_CHANNEL_ID when unset.
IFLEET_OPS_CHANNEL_ID=

# Webhook for budget-pause alerts (separate from bot-posted ops messages).
# Create one at: Discord Server Settings → Integrations → Webhooks.
DISCORD_IFLEET_WEBHOOK=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ---------------------------------------------------------------------------
# Control plane — HTTP bridge between the Discord bot and the daemon
# ---------------------------------------------------------------------------

# URL the Discord client posts to when forwarding sprint goals.
# Default in src/discord/index.ts is http://localhost:3001/control.
CONTROL_PLANE_URL=http://localhost:3001/control

# Standalone control-plane listener port. The daemon also runs an in-process
# control plane on IFLEET_DAEMON_PORT (default 3002) for ApprovalGate.
CONTROL_PLANE_PORT=3001
IFLEET_DAEMON_PORT=3002

# ---------------------------------------------------------------------------
# GitHub — queue / PR opener
# ---------------------------------------------------------------------------

# Personal access token used by the queue bridge to open PRs and post issue
# comments. Needs `repo` scope on weautomatehq1/IFleet.
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Budget guard
# ---------------------------------------------------------------------------

# Pause a sprint when cumulative spend hits this threshold (USD).
# Omit to disable budget enforcement.
BUDGET_USD=5.00

# ---------------------------------------------------------------------------
# Usage monitor — ccusage burn-rate tracking
# ---------------------------------------------------------------------------

# Max Claude API entries per 5-hour block (default: 1000)
IFLEET_BLOCK_CAP=1000

# Max Claude API entries per 7-day window (default: 20000)
IFLEET_WEEKLY_CAP=20000

# ---------------------------------------------------------------------------
# Resend — email delivery (optional, used by select rituals)
# ---------------------------------------------------------------------------

# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Knowledge graph — Supabase Postgres + pgvector (M3)
# ---------------------------------------------------------------------------

# Supabase project: ifleet-kg, region: us-east-1 (N. Virginia)
# Direct connection (local dev / migrations). VPS must use Session Pooler — port 6543.
# Get from: Supabase dashboard → Settings → Database → Connection string → Direct
IFLEET_KG_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<your-supabase-project-ref>.supabase.co:5432/postgres

# Architect feature flag — when 1, the query_code_graph tool returns the live
# graph result. When unset/0, the tool no-ops and the architect uses its
# current grep-based context (M3.W1 default).
IFLEET_KG_ENABLED=0

# Embeddings provider for the knowledge graph (M3.W2).
# Priority: Voyage AI (if key set) → Ollama local (fallback, free, no key needed).
#
# Option A — Voyage AI (hosted, best code benchmarks):
#   Get key at https://dashboard.voyageai.com/api-keys
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Option B — Transformers.js (local, in-process ONNX, no server required):
#   1. Leave VOYAGE_API_KEY unset — createEmbeddingClient() auto-picks Transformers.js.
#   2. Model downloads automatically on first use (~90MB, cached in ~/.cache/huggingface/).
#   Override model if needed (default: Xenova/jina-embeddings-v2-base-code, 768-dim):
# TRANSFORMERS_EMBED_MODEL=Xenova/jina-embeddings-v2-base-code
#
# If neither is available the indexer runs in symbolic-only mode (no embeddings).

# ---------------------------------------------------------------------------
# Canary — verifier↔reviewer disagreement-rate alerter
# ---------------------------------------------------------------------------

# Off by default. Flip on per-VPS with:
#   pm2 set ifleet-canary:IFLEET_CANARY_ALERTING_ENABLED 1
#   pm2 restart ifleet-canary
IFLEET_CANARY_ALERTING_ENABLED=0

# ---------------------------------------------------------------------------
# Audit ritual + audit-handler — claude CLI binary resolution
# ---------------------------------------------------------------------------

# Absolute path to the `claude` CLI used by scripts/audit-ritual.ts and the
# audit-fix dispatcher. The Mac default is `/opt/homebrew/bin/claude`; the VPS
# default (set by deploy/install-vps.sh) is `/usr/local/bin/claude`. Leave
# unset to let the script `which claude` and fall back to the VPS default.
CLAUDE_BIN=

# ---------------------------------------------------------------------------
# Repo roots used by multi-repo audit ritual + sync-audit-findings
# ---------------------------------------------------------------------------

# Absolute path to this IFleet checkout. Used by scripts/audit-ritual.ts to
# resolve `IFleet` repo paths; sibling repos in AUDIT_REPOS resolve to
# `<parent-of-IFLEET_REPO_ROOT>/<repo-name>`. Defaults to process.cwd().
IFLEET_REPO_ROOT=/opt/ifleet

# ---------------------------------------------------------------------------
# Worker bootstrap config (loadInitialWorkers in src/orchestrator/daemon.ts)
# ---------------------------------------------------------------------------

# Comma-separated model names assigned to the bootstrap claude-max worker.
# The real config lives in config/workers.json (reloaded on SIGHUP); this is
# only the initial value used until the file is read.
# WORKER_MODELS=claude-opus-4-7,claude-sonnet-4-6,claude-haiku-4-5-20251001

# Claude CLI auth profile name (defaults to "default").
# CLAUDE_AUTH_PROFILE=default
