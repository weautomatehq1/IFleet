# Langfuse v3 self-host secrets. Copy to deploy/langfuse/.env on the VPS and fill in.
# This file is the safe template; .env itself is gitignored.
#
# Generate the three crypto secrets ONCE then never rotate without re-encrypting:
#   openssl rand -base64 32   # NEXTAUTH_SECRET
#   openssl rand -base64 32   # SALT
#   openssl rand -hex 32      # ENCRYPTION_KEY  (must be exactly 64 hex chars)

# ---- Crypto -----------------------------------------------------------------
NEXTAUTH_SECRET="REPLACE_ME_base64_32_bytes"
SALT="REPLACE_ME_base64_32_bytes"
ENCRYPTION_KEY="REPLACE_ME_hex_64_chars"

# ---- Postgres (Langfuse's own, separate from anything else) -----------------
LANGFUSE_POSTGRES_PASSWORD="REPLACE_ME_strong_random"

# ---- ClickHouse -------------------------------------------------------------
CLICKHOUSE_PASSWORD="REPLACE_ME_strong_random"

# ---- Redis ------------------------------------------------------------------
REDIS_AUTH="REPLACE_ME_strong_random"

# ---- MinIO (internal S3) ----------------------------------------------------
MINIO_ROOT_USER="langfuse"
MINIO_ROOT_PASSWORD="REPLACE_ME_strong_random"

# ---- Initial admin user (created on first boot, ignored afterwards) ---------
# Use a real email for password-reset flows; password can be rotated in-app.
LANGFUSE_INIT_USER_EMAIL="weautomatehq1@gmail.com"
LANGFUSE_INIT_USER_NAME="Sebastian"
LANGFUSE_INIT_USER_PASSWORD="REPLACE_ME_initial_admin_password"

# ---- Optional --------------------------------------------------------------
# Disable phone-home telemetry to Langfuse cloud. Default: false (off).
TELEMETRY_ENABLED="false"
