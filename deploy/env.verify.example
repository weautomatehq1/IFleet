# .ifleet/verify-env/<repoId>.env — example for IFleet itself
# Copy to .ifleet/verify-env/weautomatehq1_IFleet.env and fill in real values.
# See docs/runbooks/secrets.md for scope guidance and rotation procedure.
#
# NEVER commit a file in .ifleet/verify-env/ — it is gitignored by design.
# NEVER add write-scoped tokens here.

# ─── GitHub ────────────────────────────────────────────────────────────────────
# READ-ONLY PAT ONLY. NO WRITE SCOPES. Scope to the specific test repos only.
# Required by: src/queue/github.ts (reads PRs + issue state in tests)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Discord ───────────────────────────────────────────────────────────────────
# Test bot token (separate from the production bot). Read + send messages only.
# Required by: src/agents/rituals/standup.ts tests
DISCORD_BOT_TOKEN=your-test-bot-token-here

# Channel ID for the test Discord channel (not #ifleet).
# Required by: src/discord/__tests__/ + observability tests
DISCORD_CHANNEL_ID=000000000000000000

# ─── Optional / future ─────────────────────────────────────────────────────────
# DISCORD_FALLBACK_CHANNEL_ID=000000000000000000
# DISCORD_IFLEET_WEBHOOK=https://discord.com/api/webhooks/...
