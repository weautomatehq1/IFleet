# IFleet VPS environment — copy entries you actually need into /etc/environment
# (one KEY="VALUE" per line, no shell expansion).
# After editing /etc/environment, you MUST `pm2 restart all --update-env`
# or reboot for PM2 to pick up changes.

# ---- Anthropic ---------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-REPLACE_ME"

# ---- GitHub ------------------------------------------------------------------
# Fine-grained PAT, weautomatehq1 org scope, Contents+Metadata write, 90-day expiry
GITHUB_TOKEN="github_pat_REPLACE_ME"

# ---- Discord -----------------------------------------------------------------
DISCORD_BOT_TOKEN="REPLACE_ME"
DISCORD_CLIENT_ID="REPLACE_ME"
DISCORD_GUILD_ID="REPLACE_ME"
# Discord channel id for #ifleet-proposals (M5 Proposer HITL posts).
# Channel does not yet exist at session close — create + paste id here.
IFLEET_PROPOSALS_CHANNEL_ID=""

# ---- Control plane HMAC ------------------------------------------------------
# Generate locally:   openssl rand -hex 32
# The same value MUST exist on the laptop side (scripts/smoke-vps.ts, slash bot)
IFLEET_HMAC_SECRET="REPLACE_ME"

# ---- Runtime paths -----------------------------------------------------------
CONTROL_PLANE_URL="http://localhost:3001/control"
IFLEET_STATE_DIR="/opt/ifleet/state"
CLAUDE_PATH="/usr/local/bin/claude"

# ---- Optional ---------------------------------------------------------------
# BUDGET_USD="50"                # daily fleet ceiling
# SENTRY_DSN=""
# RESEND_API_KEY=""
