{
  "name": "ifleet",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ifleet": "src/observability/tail-cli.ts"
  },
  "scripts": {
    "start": "node --import tsx scripts/run-smoke.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "node --import tsx --test 'src/orchestrator/**/*.test.ts' 'src/queue/**/*.test.ts' 'src/workers/**/*.test.ts' && vitest run",
    "test:watch": "vitest",
    "smoke:email": "node --import tsx scripts/smoke-email.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@octokit/plugin-throttling": "^9.3.0",
    "@octokit/rest": "^21.0.0",
    "better-sqlite3": "^11.3.0",
    "nanoid": "^5.0.7",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
