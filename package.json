{
  "name": "ifleet",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ifleet": "src/observability/tail-cli.ts"
  },
  "scripts": {
    "start": "node --import tsx scripts/run-smoke.ts",
    "start:control-plane": "node --import tsx src/server.ts",
    "dashboard": "node --import tsx dashboard/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "node --import tsx --test 'src/orchestrator/**/*.test.ts' 'src/queue/**/*.test.ts' 'src/workers/**/*.test.ts' 'src/mcp/**/*.test.ts' 'src/classifier/**/*.test.ts' && vitest run",
    "test:watch": "vitest",
    "mcp:start": "node --import tsx scripts/mcp-server.ts",
    "smoke:email": "node --import tsx scripts/smoke-email.ts",
    "deploy:commands": "node --import tsx scripts/deploy-commands.ts",
    "channels:health": "node --import tsx scripts/channels-health.ts",
    "eval:replay": "node --import tsx scripts/eval/run-eval-replay.ts",
    "eval:bootstrap": "node --import tsx scripts/eval/dump-issues.ts && node --import tsx scripts/eval/link-issues-to-prs.ts && node --import tsx scripts/eval/filter-evaluable.ts && node --import tsx scripts/eval/summarize-diffs.ts && node --import tsx scripts/eval/freeze.ts",
    "eval:freeze": "node --import tsx scripts/eval/freeze.ts",
    "graph:migrate": "node --import tsx scripts/kg/migrate.ts",
    "graph:index": "node --import tsx scripts/index-repo.ts",
    "validate-claims": "node --import tsx scripts/validate-claims.ts",
    "audit:sync": "node --import tsx scripts/sync-audit-findings.ts",
    "reviewer-cards:build": "node --import tsx scripts/build-reviewer-cards.ts",
    "dead-code": "ts-prune --ignore '(index\\.ts|__tests__|fixtures)'",
    "fleet:pause": "ssh root@${VPS_HOST:?Set VPS_HOST in your shell, e.g. export VPS_HOST=1.2.3.4} 'touch ${IFLEET_REPO_ROOT:-/opt/ifleet}/.omc/PAUSED && echo \"fleet paused\"'",
    "fleet:resume": "ssh root@${VPS_HOST:?Set VPS_HOST in your shell, e.g. export VPS_HOST=1.2.3.4} 'rm -f ${IFLEET_REPO_ROOT:-/opt/ifleet}/.omc/PAUSED && echo \"fleet resumed\"'",
    "fleet:status": "ssh root@${VPS_HOST:?Set VPS_HOST in your shell, e.g. export VPS_HOST=1.2.3.4} 'pm2 list --no-color && echo && (test -f ${IFLEET_REPO_ROOT:-/opt/ifleet}/.omc/PAUSED && echo \"[PAUSED]\" || echo \"[RUNNING]\")'",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/plugin-throttling": "^9.3.0",
    "@octokit/rest": "^21.0.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.3.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "langfuse": "^3.38.20",
    "nanoid": "^5.0.7",
    "pg": "^8.13.1",
    "resend": "^6.12.3",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "tsx": "^4.0.0",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "tree-sitter",
      "tree-sitter-typescript"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "ccusage": "^15.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "ts-prune": "^0.10.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
