{
  "$schema": "./routing.schema.json",
  "tiers": {
    "haiku": "claude-haiku-4-5-20251001",
    "sonnet": "claude-sonnet-4-6",
    "opus": "claude-opus-4-8"
  },
  "modes": {
    "ralph": {
      "architect": "claude-sonnet-4-6",
      "editor": "claude-sonnet-4-6",
      "verify": ["typecheck", "lint", "test"]
    },
    "ulw": {
      "architect": "claude-sonnet-4-6",
      "editor": "claude-sonnet-4-6"
    },
    "tdd": {
      "architect": "claude-sonnet-4-6",
      "editor": "claude-sonnet-4-6",
      "verify": ["typecheck", "lint", "test"]
    },
    "deslop": {
      "architect": "claude-haiku-4-5-20251001",
      "editor": "claude-sonnet-4-6"
    },
    "standard": {}
  },
  "rules": [
    {
      "match": { "keywords": ["architect", "design", "security", "auth", "migration", "rls", "critical"] },
      "route": { "provider": "claude", "model": "claude-opus-4-8", "role": "architect" }
    },
    {
      "match": { "keywords": ["refactor", "rename", "boilerplate", "test gen", "stub", "format"] },
      "route": { "provider": "claude", "model": "claude-sonnet-4-6", "role": "editor" }
    },
    {
      "match": { "fileGlobs": ["**/*.tsx", "**/*.css", "app/**", "components/**"] },
      "route": { "provider": "claude", "model": "claude-sonnet-4-6", "role": "editor", "verify": ["typecheck", "lint", "test", "playwright"] }
    },
    {
      "match": { "fileGlobs": ["**/*.sql", "migrations/**", "supabase/**"] },
      "route": { "provider": "claude", "model": "claude-opus-4-8", "role": "architect" }
    }
  ],
  "pipeline": {
    "architect": { "provider": "claude", "model": "claude-sonnet-4-6" },
    "editor": { "provider": "claude", "model": "claude-sonnet-4-6", "switchable": { "provider": "codex", "model": "gpt-5.5-codex" } },
    "reviewer": { "rule": "opposite-provider-of-editor", "model": "claude-sonnet-4-6" },
    "planReviewer": {
      "rule": "not-weaker-than-architect",
      "default": { "provider": "claude", "model": "claude-haiku-4-5-20251001" },
      "floors": {
        "claude-opus-4-8": "claude-sonnet-4-6",
        "claude-sonnet-4-6": "claude-haiku-4-5-20251001",
        "claude-haiku-4-5-20251001": "claude-haiku-4-5-20251001"
      },
      "costCapPctOfArchitect": 10,
      "maxVetoes": 2
    }
  },
  "verify": {
    "default": ["typecheck", "lint", "test"],
    "ui": ["typecheck", "lint", "test", "playwright", "screenshot"]
  }
}
