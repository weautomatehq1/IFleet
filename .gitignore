# Dependencies
node_modules
node_modules/
node_modules

# Build artifacts
dist/
*.tsbuildinfo

# Local env
.env
.env.local
.env.*.local

# Claude Code local config — never commit to a public repo
.claude/

# Editor
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.swp
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime state
.omc/state/
.omc/logs/
.omc/sprints/
.omc/PAUSED

# Audit findings — written by /audit-scan and /audit-fix, public repo
.audits/
state.db
state.db-journal
*.sqlite
*.sqlite-journal
# Prod IFLEET_STATE_DIR (defaults to <repo>/state on the VPS).
state/

# Secrets
secrets/
*.pem
*.key

# Per-repo verify-env files (contain PATs/tokens, never committed)
.ifleet/verify-env/*
!.ifleet/verify-env/.gitkeep

# Audit findings (local only, never committed)
.audits/
