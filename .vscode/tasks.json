{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "typecheck",
      "type": "shell",
      "command": "pnpm typecheck",
      "problemMatcher": "$tsc",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "pnpm lint",
      "problemMatcher": "$eslint-stylish",
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "test",
      "type": "shell",
      "command": "pnpm test",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "group": { "kind": "test", "isDefault": true }
    },
    {
      "label": "test:watch",
      "type": "shell",
      "command": "pnpm test:watch",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "fleet:status",
      "type": "shell",
      "command": "pnpm fleet:status",
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "fleet:pause",
      "type": "shell",
      "command": "pnpm fleet:pause",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "fleet:resume",
      "type": "shell",
      "command": "pnpm fleet:resume",
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}
